# Supabase — Partner Collective project
# Project Settings → API. The publishable key is safe to expose in the browser.
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=your-publishable-key

# Server-only Supabase secret/service-role key used by API routes to link the
# private customer timeline. Never expose this in NEXT_PUBLIC_*.
SUPABASE_SECRET_KEY=sb_secret_xxx
# SUPABASE_SERVICE_ROLE_KEY=service-role-key-alias

# Where new-interest notifications are sent (defaults to sadya@goflow.com).
COLLECTIVE_NOTIFY_EMAIL=sadya@goflow.com

# Public site URL used in confirmation emails.
COLLECTIVE_SITE_URL=https://goflowpartnercollective.com

# Optional: email notifications via Resend (https://resend.com).
# Leave unset and leads are still saved to Supabase — email is a bonus.
# RESEND_API_KEY=re_xxx
# COLLECTIVE_NOTIFY_FROM=Goflow Partner Collective <partners@goflowpartnercollective.com>

# Optional: send every registration/application to a CRM automation webhook
# after Supabase capture and notification email. Use this for Pipedrive/Pindu,
# Zapier, Make, HubSpot workflows, or a custom lead router.
# COLLECTIVE_LEAD_WEBHOOK_URL=https://hooks.example.com/collective-lead
# COLLECTIVE_LEAD_WEBHOOK_SECRET=shared-secret-for-verification
